{% extends 'base.html.twig' %}

{% block title %}Portfolios{% endblock %}

{% block body %}
<div class="min-h-screen bg-primary">

    <main class="px-4 pt-2 pb-6 md:px-8">
        <div class="max-w-7xl mx-auto">

            {% if portfolios|length > 0 %}
                <!-- Summary Cards -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                    <!-- Combined Portfolio Value -->
                    <div class="bg-card rounded-2xl p-6">
                        <h2 class="text-gray-400 text-sm font-medium mb-3">Combined Portfolio Value</h2>
                        <div class="flex items-baseline gap-3">
                            <span class="text-3xl font-bold text-white">{{ combined.totalValue|format_price }}</span>
                            <span class="text-sm">
                                <span class="text-gray-400">24h</span>
                                <span class="ml-1 {% if combined.change24h >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                                    {% if combined.change24h >= 0 %}+{% endif %}{{ combined.change24h|number_format(1) }}%
                                </span>
                            </span>
                        </div>
                    </div>

                    <!-- Total Profit & Loss -->
                    <div class="bg-card rounded-2xl p-6">
                        <h2 class="text-gray-400 text-sm font-medium mb-3">Combined Profit & Loss</h2>
                        <div class="flex items-baseline gap-3">
                            <span class="text-3xl font-bold {% if combined.profitLoss >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                                {% if combined.profitLoss >= 0 %}+{% endif %}{{ combined.profitLoss|format_price }}
                            </span>
                            <span class="text-sm {% if combined.profitLossPercent >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                                {% if combined.profitLossPercent >= 0 %}+{% endif %}{{ combined.profitLossPercent|number_format(1) }}%
                            </span>
                        </div>
                    </div>

                    <!-- Portfolio Distribution -->
                    <div class="bg-card rounded-2xl p-6">
                        <h2 class="text-gray-400 text-sm font-medium mb-3">Portfolio Distribution</h2>
                        <div class="flex items-center justify-between">
                            <div class="space-y-1 max-h-[130px] overflow-y-auto 
                                    [mask-image:linear-gradient(to_bottom,black_90%,transparent_100%)]
                                    [&::-webkit-scrollbar]:w-1
                                    [&::-webkit-scrollbar-thumb]:bg-accent
                                    [&::-webkit-scrollbar-thumb]:rounded-full"
                                >
                                {% for portfolio in portfolios %}
                                    {% set portfolioSummary = combined.portfolioSummaries[portfolio.id] ?? null %}
                                    {% set portfolioPercent = (combined.totalValue > 0 and portfolioSummary) ? (portfolioSummary.totalValue / combined.totalValue * 100) : 0 %}
                                    <div class="flex items-center gap-2">
                                        <span class="w-3 h-3 rounded-full flex-shrink-0" style="background-color: {{ distributionColors[loop.index0] }}"></span>
                                        <span class="text-gray-300 text-sm">{{ portfolio.name }} - {{ portfolioPercent|number_format(1) }}%</span>
                                    </div>
                                {% endfor %}
                            </div>
                            <div class="ml-auto w-30 h-30 min-w-[6rem] flex-shrink-0">
                                {{ render_chart(distributionChart) }}
                            </div>
                        </div>
                    </div>
                </div>

                <!-- All Portfolios Table -->
                <div class="bg-card rounded-2xl p-4 md:p-6">
                    <!-- Header -->
                    <div class="flex flex-col gap-4 mb-6">
                        <div class="flex items-center justify-between gap-2">
                            <h2 class="text-xl font-semibold text-white">All Portfolios</h2>
                            <a href="{{ path('app_portfolio_new') }}" class="px-4 py-2 text-white rounded-lg transition-colors bg-accent hover:opacity-90 text-sm font-medium flex-shrink-0">
                                Add Portfolio
                            </a>
                        </div>
                        <form method="get" action="{{ path('app_portfolio_index') }}" class="flex flex-col gap-2 md:flex-row md:items-center md:gap-2">
                            <input type="text" name="q" value="{{ searchTerm }}" placeholder="Search portfolios by name..."
                                class="w-full md:w-auto md:min-w-[200px] flex-1 bg-gray-800 text-white px-4 py-2 rounded-lg border border-gray-700 focus:outline-none focus:border-accent">
                            <div class="flex gap-2">
                                <button type="submit" class="flex-1 md:flex-none bg-accent px-4 py-2 rounded-lg text-white font-medium hover:bg-purple-600 transition-colors">
                                    Search
                                </button>
                                {% if searchTerm %}
                                    <a href="{{ path('app_portfolio_index') }}" class="flex-1 md:flex-none text-center text-gray-400 hover:text-white px-4 py-2 rounded-lg border border-gray-600 hover:border-gray-500 transition-colors">
                                        Clear
                                    </a>
                                {% endif %}
                            </div>
                        </form>
                    </div>

                    <!-- Desktop Table -->
                    <div class="hidden md:block">
                        <!-- Table Header -->
                        <div class="grid grid-cols-5 gap-4 px-4 pb-4 border-b border-primary">
                            <div class="text-gray-400 text-sm font-medium hover:text-white transition-colors">
                                {{ knp_pagination_sortable(pagination, 'Name', 'p.name', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                            </div>
                            <div class="text-gray-400 text-sm font-medium hover:text-white transition-colors">
                                {{ knp_pagination_sortable(pagination, 'Value', 'total_value', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                            </div>
                            <div class="text-gray-400 text-sm font-medium hover:text-white transition-colors">
                                {{ knp_pagination_sortable(pagination, 'P&L', 'profit_loss_percent', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                            </div>
                            <div class="text-gray-400 text-sm font-medium hover:text-white transition-colors">
                                {{ knp_pagination_sortable(pagination, '24h', 'change_24h', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                            </div>
                            <div></div>
                        </div>

                        <!-- Table Rows -->
                        {% if pagination|length > 0 %}
                            {% for portfolio in pagination %}
                                {% set portfolioSummary = combined.portfolioSummaries[portfolio.id] ?? null %}
                                <a href="{{ path('app_portfolio_show', {'id': portfolio.id}) }}" class="grid gap-4 px-4 py-4 items-center border-b border-primary transition-colors hover:bg-[#2a2f3d]" style="grid-template-columns: 1fr 1.2fr 0.6fr 0.5fr auto;">
                                    <div class="text-white font-medium">{{ portfolio.name }}</div>
                                    <div class="text-white">{{ portfolioSummary ? portfolioSummary.totalValue|format_value_short : '$0.00' }}</div>
                                    <div>
                                        {% if portfolioSummary %}
                                            <span class="{% if portfolioSummary.profitLossPercent >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                                                {% if portfolioSummary.profitLossPercent >= 0 %}+{% endif %}{{ portfolioSummary.profitLossPercent|number_format(1) }}%
                                            </span>
                                        {% else %}
                                            <span class="text-gray-400">0.0%</span>
                                        {% endif %}
                                    </div>
                                    <div>
                                        {% if portfolioSummary %}
                                            <span class="{% if portfolioSummary.change24h >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                                                {% if portfolioSummary.change24h >= 0 %}+{% endif %}{{ portfolioSummary.change24h|number_format(1) }}%
                                            </span>
                                        {% else %}
                                            <span class="text-gray-400">0.0%</span>
                                        {% endif %}
                                    </div>
                                    <div class="text-right">
                                        <span class="text-gray-400">
                                            <svg class="w-5 h-5 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                            </svg>
                                        </span>
                                    </div>
                                </a>
                            {% endfor %}
                        {% else %}
                            <div class="text-center text-gray-400 py-4">No portfolios found.</div>
                        {% endif %}
                    </div>

                    <!-- Mobile Table -->
                    <div class="md:hidden grid gap-x-2 gap-y-0 px-1 min-w-0 overflow-hidden" style="grid-template-columns: minmax(0, 0.65fr) minmax(0, 1.15fr) minmax(0, 0.55fr) minmax(0, 0.5fr);">
                        <!-- Header row -->
                        <div class="text-gray-400 text-xs font-medium hover:text-white transition-colors py-2 border-b border-primary flex items-center min-w-0">
                            {{ knp_pagination_sortable(pagination, 'Name', 'p.name', { class: 'inline-flex items-center gap-1 cursor-pointer truncate' }, [], 'components/_sortable_link.html.twig') }}
                        </div>
                        <div class="text-gray-400 text-xs font-medium hover:text-white transition-colors py-2 border-b border-primary text-right min-w-0 flex items-center justify-end">
                            {{ knp_pagination_sortable(pagination, 'Value', 'total_value', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                        </div>
                        <div class="text-gray-400 text-xs font-medium hover:text-white transition-colors py-2 border-b border-primary text-right min-w-0 flex items-center justify-end">
                            {{ knp_pagination_sortable(pagination, 'P&L', 'profit_loss_percent', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                        </div>
                        <div class="text-gray-400 text-xs font-medium hover:text-white transition-colors py-2 border-b border-primary text-right min-w-0 flex items-center justify-end">
                            {{ knp_pagination_sortable(pagination, '24h', 'change_24h', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                        </div>

                        {% if pagination|length > 0 %}
                            {% for portfolio in pagination %}
                                {% set portfolioSummary = combined.portfolioSummaries[portfolio.id] ?? null %}
                                <a href="{{ path('app_portfolio_show', {'id': portfolio.id}) }}" class="py-2 border-b border-primary flex items-center min-w-0 col-span-1">
                                    <span class="text-white text-sm font-medium truncate">{{ portfolio.name }}</span>
                                </a>
                                <a href="{{ path('app_portfolio_show', {'id': portfolio.id}) }}" class="text-white text-sm text-right py-2 border-b border-primary min-w-0 flex items-center justify-end col-span-1">{{ portfolioSummary ? portfolioSummary.totalValue|format_price : '$0.00' }}</a>
                                <a href="{{ path('app_portfolio_show', {'id': portfolio.id}) }}" class="py-2 border-b border-primary min-w-0 flex items-center justify-end col-span-1">
                                    {% if portfolioSummary %}
                                        <span class="text-sm {% if portfolioSummary.profitLossPercent >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                                            {% if portfolioSummary.profitLossPercent >= 0 %}+{% endif %}{{ portfolioSummary.profitLossPercent|number_format(1) }}%
                                        </span>
                                    {% else %}
                                        <span class="text-gray-400 text-sm">0.0%</span>
                                    {% endif %}
                                </a>
                                <a href="{{ path('app_portfolio_show', {'id': portfolio.id}) }}" class="py-2 border-b border-primary min-w-0 flex items-center justify-end col-span-1">
                                    {% if portfolioSummary %}
                                        <span class="text-sm {% if portfolioSummary.change24h >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                                            {% if portfolioSummary.change24h >= 0 %}+{% endif %}{{ portfolioSummary.change24h|number_format(1) }}%
                                        </span>
                                    {% else %}
                                        <span class="text-gray-400 text-sm">0.0%</span>
                                    {% endif %}
                                </a>
                            {% endfor %}
                        {% else %}
                            <div class="col-span-4 text-center text-gray-400 py-4">No portfolios found.</div>
                        {% endif %}
                    </div>
                        {{ knp_pagination_render(pagination, 'components/_pagination.html.twig') }}
                    </div>
            {% else %}
                <!-- No Portfolios -->
                <div class="bg-card rounded-2xl p-8 text-center">
                    <p class="text-xl text-gray-200 mb-6">You don't have any portfolios yet.</p>
                    <a href="{{ path('app_portfolio_new') }}" class="inline-block px-6 py-3 text-white rounded-lg transition-colors bg-accent hover:opacity-90 font-medium">
                        Add Portfolio
                    </a>
                </div>
            {% endif %}
        </div>
    </main>
</div>
{% endblock %}

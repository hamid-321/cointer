{% extends 'base.html.twig' %}

{% block title %}{{ portfolio.name }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-primary">

    <main class="px-4 pt-2 pb-6 md:px-8">
        <div class="max-w-7xl mx-auto">

            <!-- Back and edit/delete -->
            <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
                <a href="{{ path('app_portfolio_index') }}" class="text-gray-400 text-md hover:text-white transition-colors">
                    &larr; Back to Portfolios
                </a>
                <div class="flex items-center gap-2">
                    <a href="{{ path('app_portfolio_edit', {'id': portfolio.id}) }}" class="px-2 py-1 text-s font-medium bg-slate-500/20 text-slate-300 hover:bg-slate-500/30 border border-slate-500/50 rounded transition-colors">
                        <span class="sm:hidden">Edit</span><span class="hidden sm:inline">Edit Portfolio</span>
                    </a>
                    {% include 'portfolio/_delete_form.html.twig' with { portfolio: portfolio } %}
                </div>
            </div>

            <!-- Summary Cards -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                <!-- Portfolio Value -->
                <div class="bg-card rounded-2xl p-6">
                    <h2 class="text-gray-400 text-md font-medium mb-3">{{ portfolio.name }} Value</h2>
                    <div class="flex items-baseline gap-3">
                        <span class="text-3xl font-bold text-white">{{ summary.totalValue|format_price }}</span>
                        <span class="text-sm">
                            <span class="text-gray-400">24h</span>
                            <span class="ml-1 {% if summary.change24h >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                                {% if summary.change24h >= 0 %}+{% endif %}{{ summary.change24h|number_format(1) }}%
                            </span>
                        </span>
                    </div>
                </div>

                <!-- Profit & Loss -->
                <div class="bg-card rounded-2xl p-6">
                    <h2 class="text-gray-400 text-md font-medium mb-3">Profit & Loss</h2>
                    <div class="flex items-baseline gap-3">
                        <span class="text-3xl font-bold {% if summary.profitLoss >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                            {% if summary.profitLoss >= 0 %}+{% endif %}{{ summary.profitLoss|format_price }}
                        </span>
                        <span class="text-sm {% if summary.profitLossPercent >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                            {% if summary.profitLossPercent >= 0 %}+{% endif %}{{ summary.profitLossPercent|number_format(1) }}%
                        </span>
                    </div>
                </div>

                <!-- Portfolio Distribution -->
                <div class="bg-card rounded-2xl p-6">
                    <h2 class="text-gray-400 text-md font-medium mb-3">Coin Distribution</h2>
                    <div class="flex items-center justify-between">
                        <div class="space-y-1 max-h-[130px] overflow-y-auto 
                                    [mask-image:linear-gradient(to_bottom,black_90%,transparent_100%)]
                                    [&::-webkit-scrollbar]:w-1
                                    [&::-webkit-scrollbar-thumb]:bg-accent
                                    [&::-webkit-scrollbar-thumb]:rounded-full"
                                >
                            {% if holdings|length > 0 %}
                                {% for item in holdings %}
                                    <div class="flex items-center gap-2">
                                        <span class="w-3 h-3 rounded-full flex-shrink-0" style="background-color: {{ distributionColors[loop.index0] }}"></span>
                                        <span class="text-gray-300 text-sm">{{ item.coin.name }} - {{ summary.totalValue > 0 ? (item.currentValue / summary.totalValue * 100)|number_format(1) : 0 }}%</span>
                                    </div>
                                {% endfor %}
                            {% else %}
                                <span class="text-gray-500 text-sm">No coins yet.</span>
                            {% endif %}
                        </div>
                        <div class="w-30 h-30 min-w-[6rem] flex-shrink-0">
                            {{ render_chart(distributionChart) }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- All Coins Table -->
            <div class="bg-card rounded-2xl p-4 md:p-6">
                <!-- Header -->
                <div class="flex flex-col gap-4 mb-6">
                    <div class="flex items-center justify-between gap-2">
                        <h2 class="text-xl font-semibold text-white">Held Coins</h2>
                        <a href="{{ path('app_transaction_new', {'id': portfolio.id}) }}" class="px-4 py-2 text-white rounded-lg transition-colors bg-accent hover:opacity-90 text-sm font-medium flex-shrink-0">
                            Add Coin
                        </a>
                    </div>
                    <form method="get" action="{{ path('app_portfolio_show', {'id': portfolio.id}) }}" class="flex flex-col gap-2 md:flex-row md:items-center md:gap-2">
                        <input type="text" name="q" value="{{ searchTerm }}" placeholder="Search coins by name..."
                            class="w-full md:w-auto md:min-w-[200px] flex-1 bg-gray-800 text-white px-4 py-2 rounded-lg border border-gray-700 focus:outline-none focus:border-accent">
                        <div class="flex gap-2">
                            <button type="submit" class="flex-1 md:flex-none bg-accent px-4 py-2 rounded-lg text-white font-medium hover:bg-purple-600 transition-colors">
                                Search
                            </button>
                            {% if searchTerm %}
                                <a href="{{ path('app_portfolio_show', {'id': portfolio.id}) }}" class="flex-1 md:flex-none text-center text-gray-400 hover:text-white px-4 py-2 rounded-lg border border-gray-600 hover:border-gray-500 transition-colors">
                                    Clear
                                </a>
                            {% endif %}
                        </div>
                    </form>
                </div>

                {% if pagination|length > 0 %}
                    <!-- Desktop Table -->
                    <div class="hidden md:block">
                        <!-- Table Header -->
                        <div class="grid grid-cols-7 gap-4 px-4 pb-4 border-b border-primary">
                            <div class="text-gray-400 text-sm font-medium hover:text-white transition-colors">
                                {{ knp_pagination_sortable(pagination, 'Name', 'c.name', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                            </div>
                            <div class="text-gray-400 text-sm font-medium hover:text-white transition-colors">
                                {{ knp_pagination_sortable(pagination, 'Holdings', 'net_quantity', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                            </div>
                            <div class="text-gray-400 text-sm font-medium hover:text-white transition-colors">
                                {{ knp_pagination_sortable(pagination, 'Holdings Value', 'current_value', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                            </div>
                            <div class="text-gray-400 text-sm font-medium hover:text-white transition-colors">
                                {{ knp_pagination_sortable(pagination, 'Current Price', 'c.price', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                            </div>
                            <div class="text-gray-400 text-sm font-medium hover:text-white transition-colors">
                                {{ knp_pagination_sortable(pagination, 'P&L', 'profit_loss_percent', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                            </div>
                            <div class="text-gray-400 text-sm font-medium hover:text-white transition-colors">
                                {{ knp_pagination_sortable(pagination, '24h', 'change_24h', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                            </div>
                            <div></div>
                        </div>

                        {% for coin in pagination %}
                            {% set holding = summary.holdings[coin.id] ?? null %}
                            <a href="{{ path('app_portfolio_coin', {'id': portfolio.id, 'coinId': coin.id}) }}" class="grid grid-cols-7 gap-4 px-4 py-4 items-center border-b border-primary transition-colors hover:bg-[#2a2f3d]">
                                <div>
                                    <div class="text-white font-medium">{{ coin.name }}</div>
                                    <div class="text-gray-400 text-sm uppercase">{{ coin.symbol }}</div>
                                </div>
                                <div class="text-white">{{ holding.quantity|format_holdings }}</div>
                                <div class="text-white">{{ holding.currentValue|format_price }}</div>
                                <div class="text-white">{{ coin.price|format_price }}</div>
                                <div>
                                    <span class="{% if holding.profitLossPercent >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                                        {% if holding.profitLossPercent >= 0 %}+{% endif %}{{ holding.profitLossPercent|number_format(1) }}%
                                    </span>
                                </div>
                                <div>
                                    <span class="{% if holding.change24h >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                                        {% if holding.change24h >= 0 %}+{% endif %}{{ holding.change24h|number_format(1) }}%
                                    </span>
                                </div>
                                <div class="text-right">
                                    <span class="text-gray-400">
                                        <svg class="w-5 h-5 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                        </svg>
                                    </span>
                                </div>
                            </a>
                        {% endfor %}
                    </div>

                    <!-- Mobile Table: Name gets less space (truncates); Value gets more so full amount shows -->
                    <div class="md:hidden grid gap-x-2 gap-y-0 px-1 min-w-0 overflow-hidden" style="grid-template-columns: minmax(0, 0.6fr) minmax(0, 0.65fr) minmax(0, 1.15fr) minmax(0, 0.5fr);">
                        <!-- Header row -->
                        <div class="text-gray-400 text-xs font-medium hover:text-white transition-colors py-2 border-b border-primary flex items-center min-w-0 overflow-hidden">
                            {{ knp_pagination_sortable(pagination, 'Name', 'c.name', { class: 'inline-flex items-center gap-1 cursor-pointer truncate min-w-0' }, [], 'components/_sortable_link.html.twig') }}
                        </div>
                        <div class="text-gray-400 text-xs font-medium hover:text-white transition-colors py-2 border-b border-primary text-right min-w-0 flex items-center justify-end">
                            {{ knp_pagination_sortable(pagination, 'Holdings', 'net_quantity', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                        </div>
                        <div class="text-gray-400 text-xs font-medium hover:text-white transition-colors py-2 border-b border-primary text-right min-w-0 flex items-center justify-end">
                            {{ knp_pagination_sortable(pagination, 'Value', 'current_value', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                        </div>
                        <div class="text-gray-400 text-xs font-medium hover:text-white transition-colors py-2 border-b border-primary text-right min-w-0 flex items-center justify-end">
                            {{ knp_pagination_sortable(pagination, '24h', 'change_24h', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                        </div>

                        {% for coin in pagination %}
                            {% set holding = summary.holdings[coin.id] ?? null %}
                            <a href="{{ path('app_portfolio_coin', {'id': portfolio.id, 'coinId': coin.id}) }}" class="py-2 border-b border-primary flex items-center min-w-0 col-span-1 transition-colors hover:bg-[#2a2f3d] overflow-hidden">
                                <div class="min-w-0 truncate">
                                    <div class="text-white text-sm font-medium truncate">{{ coin.name }}</div>
                                    <div class="text-gray-400 text-xs uppercase">{{ coin.symbol }}</div>
                                </div>
                            </a>
                            <a href="{{ path('app_portfolio_coin', {'id': portfolio.id, 'coinId': coin.id}) }}" class="text-white text-sm text-right py-2 border-b border-primary min-w-0 flex items-center justify-end col-span-1 transition-colors hover:bg-[#2a2f3d]">{{ holding.quantity|format_holdings }}</a>
                            <a href="{{ path('app_portfolio_coin', {'id': portfolio.id, 'coinId': coin.id}) }}" class="text-white text-sm text-right py-2 border-b border-primary min-w-0 flex items-center justify-end col-span-1 transition-colors hover:bg-[#2a2f3d]">{{ holding.currentValue|format_price }}</a>
                            <a href="{{ path('app_portfolio_coin', {'id': portfolio.id, 'coinId': coin.id}) }}" class="py-2 border-b border-primary min-w-0 flex items-center justify-end col-span-1 transition-colors hover:bg-[#2a2f3d]">
                                <span class="text-sm {% if holding.change24h >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                                    {% if holding.change24h >= 0 %}+{% endif %}{{ holding.change24h|number_format(1) }}%
                                </span>
                            </a>
                        {% endfor %}
                    </div>

                    {{ knp_pagination_render(pagination, 'components/_pagination.html.twig') }}
                {% else %}
                    <div class="py-8 text-center text-gray-400">
                        No coins in this portfolio yet. Add your first coin to get started.
                    </div>
                {% endif %}
            </div>

        </div>
    </main>
</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}{{ portfolio.name }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-primary">
    {% include 'components/_navbar.html.twig' %}

    <main class="px-4 pt-2 pb-6 md:px-8">
        <div class="max-w-7xl mx-auto">

            <!-- Back Link -->
            <div class="mb-4">
                <a href="{{ path('app_portfolio_index') }}" class="text-gray-400 text-md hover:text-white transition-colors">
                    &larr; Back to Portfolios
                </a>
            </div>

            <!-- Summary Cards -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                <!-- Portfolio Value -->
                <div class="bg-card rounded-2xl p-6">
                    <h2 class="text-gray-400 text-sm font-medium mb-3">{{ portfolio.name }} Value</h2>
                    <div class="flex items-baseline gap-3">
                        <span class="text-3xl font-bold text-white">{{ summary.totalValue|format_price }}</span>
                        <span class="text-sm">
                            <span class="text-gray-400">24h</span>
                            <span class="ml-1 {% if summary.change24h >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                                {% if summary.change24h >= 0 %}+{% endif %}{{ summary.change24h|number_format(1) }}%
                            </span>
                        </span>
                    </div>
                </div>

                <!-- Profit & Loss -->
                <div class="bg-card rounded-2xl p-6">
                    <h2 class="text-gray-400 text-sm font-medium mb-3">Profit & Loss</h2>
                    <div class="flex items-baseline gap-3">
                        <span class="text-3xl font-bold {% if summary.profitLoss >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                            {% if summary.profitLoss >= 0 %}+{% endif %}{{ summary.profitLoss|format_price }}
                        </span>
                        <span class="text-sm {% if summary.profitLossPercent >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                            {% if summary.profitLossPercent >= 0 %}+{% endif %}{{ summary.profitLossPercent|number_format(1) }}%
                        </span>
                    </div>
                </div>

                <!-- Portfolio Distribution -->
                <div class="bg-card rounded-2xl p-6">
                    <h2 class="text-gray-400 text-sm font-medium mb-3">Coin Distribution</h2>
                    <div class="flex items-center justify-between">
                        <div class="space-y-1 max-h-[130px] overflow-y-auto 
                                    [mask-image:linear-gradient(to_bottom,black_90%,transparent_100%)]
                                    [&::-webkit-scrollbar]:w-1
                                    [&::-webkit-scrollbar-thumb]:bg-accent
                                    [&::-webkit-scrollbar-thumb]:rounded-full"
                                >
                            {% if holdings|length > 0 %}
                                {% for item in holdings %}
                                    <div class="flex items-center gap-2">
                                        <span class="w-3 h-3 rounded-full flex-shrink-0" style="background-color: {{ distributionColors[loop.index0] }}"></span>
                                        <span class="text-gray-300 text-sm">{{ item.coin.name }} - {{ summary.totalValue > 0 ? (item.currentValue / summary.totalValue * 100)|number_format(1) : 0 }}%</span>
                                    </div>
                                {% endfor %}
                            {% else %}
                                <span class="text-gray-500 text-sm">No coins yet</span>
                            {% endif %}
                        </div>
                        <div class="w-30 h-30 min-w-[6rem] flex-shrink-0">
                            {{ render_chart(distributionChart) }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- All Coins Table -->
            <div class="bg-card rounded-2xl p-4 md:p-6">
                <!-- Header -->
                <div class="flex items-center justify-between gap-4 mb-6">
                    <h2 class="text-xl font-semibold text-white">All Coins</h2>
                    <a href="{{ path('app_transaction_new', {'id': portfolio.id}) }}" class="px-4 py-2 text-white rounded-lg transition-colors bg-accent hover:opacity-90 text-sm font-medium">
                        Add Coin
                    </a>
                </div>

                {% if holdings|length > 0 %}
                    <!-- Desktop Table -->
                    <div class="hidden md:block">
                        <!-- Table Header -->
                        <div class="grid grid-cols-7 gap-4 px-4 pb-4 border-b border-primary">
                            <div class="text-gray-400 text-sm font-medium">Name</div>
                            <div class="text-gray-400 text-sm font-medium">Holdings</div>
                            <div class="text-gray-400 text-sm font-medium">Holdings Value</div>
                            <div class="text-gray-400 text-sm font-medium">Current Price</div>
                            <div class="text-gray-400 text-sm font-medium">P&L</div>
                            <div class="text-gray-400 text-sm font-medium">24h</div>
                            <div></div>
                        </div>

                        {% for holding in holdings %}
                            {% set coin = holding.coin %}
                            <a href="{{ path('app_portfolio_coin', {'id': portfolio.id, 'coinId': coin.id}) }}" class="grid grid-cols-7 gap-4 px-4 py-4 items-center border-b border-primary transition-colors hover:bg-[#2a2f3d]">
                                <div>
                                    <div class="text-white font-medium">{{ coin.name }}</div>
                                    <div class="text-gray-400 text-sm uppercase">{{ coin.symbol }}</div>
                                </div>
                                <div class="text-white">{{ holding.quantity }}</div>
                                <div class="text-white">{{ holding.currentValue|format_price }}</div>
                                <div class="text-white">{{ coin.price|format_price }}</div>
                                <div>
                                    <span class="{% if holding.profitLossPercent >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                                        {% if holding.profitLossPercent >= 0 %}+{% endif %}{{ holding.profitLossPercent|number_format(1) }}%
                                    </span>
                                </div>
                                <div>
                                    <span class="{% if holding.change24h >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                                        {% if holding.change24h >= 0 %}+{% endif %}{{ holding.change24h|number_format(1) }}%
                                    </span>
                                </div>
                                <div class="text-right">
                                    <span class="text-gray-400">
                                        <svg class="w-5 h-5 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                        </svg>
                                    </span>
                                </div>
                            </a>
                        {% endfor %}
                    </div>

                    <!-- Mobile Table -->
                    <div class="md:hidden">
                        <!-- Mobile Header -->
                        <div class="grid grid-cols-4 px-1 pb-2 border-b border-primary">
                            <div class="text-gray-400 text-xs font-medium">Name</div>
                            <div class="text-gray-400 text-xs font-medium text-right">Holdings</div>
                            <div class="text-gray-400 text-xs font-medium text-right">Value</div>
                            <div class="text-gray-400 text-xs font-medium text-right">24h</div>
                        </div>

                        {% for holding in holdings %}
                            {% set coin = holding.coin %}
                            <a href="{{ path('app_portfolio_coin', {'id': portfolio.id, 'coinId': coin.id}) }}" class="grid grid-cols-4 px-1 py-2 items-center border-b border-primary transition-colors hover:bg-[#2a2f3d]">
                                <div class="min-w-0">
                                    <div class="text-white text-sm font-medium truncate">{{ coin.name }}</div>
                                    <div class="text-gray-400 text-xs uppercase">{{ coin.symbol }}</div>
                                </div>
                                <div class="text-white text-sm text-right">{{ holding.quantity }}</div>
                                <div class="text-white text-sm text-right">{{ holding.currentValue|format_price }}</div>
                                <div class="text-right">
                                    <span class="text-sm {% if holding.change24h >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                                        {% if holding.change24h >= 0 %}+{% endif %}{{ holding.change24h|number_format(1) }}%
                                    </span>
                                </div>
                            </a>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="py-8 text-center text-gray-400">
                        No coins in this portfolio yet. Add your first coin to get started.
                    </div>
                {% endif %}
            </div>

        </div>
    </main>
</div>
{% endblock %}

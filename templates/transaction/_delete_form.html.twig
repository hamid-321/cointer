<form method="post" action="{{ path('app_transaction_delete', {'id': portfolio.id, 'transactionId': transaction.id}) }}" class="inline">
    <input type="hidden" name="_token" value="{{ csrf_token('delete-transaction-' ~ transaction.id) }}">
    <button type="button" class="px-2 py-1 text-xs font-medium bg-red-500/10 text-red-400 hover:bg-red-500/20 border border-red-500/30 rounded transition-colors" data-action="click->confirm#open" data-confirm-message="Are you sure you want to delete this transaction?" aria-label="Delete this transaction">
        Delete
    </button>
</form>
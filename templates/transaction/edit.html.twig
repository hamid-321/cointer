{% extends 'base.html.twig' %}

{% block title %}Edit Transaction - {{ portfolio.name }}{% endblock %}

{% block body %}

    <div class="min-h-[calc(100vh-4rem)] bg-primary flex items-center justify-center px-4 py-4">
        <div class="w-full max-w-sm">
            <div class="bg-card shadow rounded-lg p-6 max-h-full overflow-auto">
                <h1 class="text-2xl font-semibold text-white mb-2 text-center">Edit Transaction</h1>
                <p class="text-gray-400 text-sm text-center mb-6">{{ portfolio.name }}</p>

                {% include 'transaction/_form.html.twig' with { button_label: 'Save Changes', balance_url: path('app_portfolio_coin_balance', { id: portfolio.id }), exclude_transaction_id: transaction.id } %}

                <p class="mt-6 text-center">
                    <a href="{{ path('app_portfolio_coin', {'id': portfolio.id, 'coinId': transaction.coin.id}) }}" class="text-gray-400 text-md hover:text-white transition-colors">Cancel</a>
                </p>
            </div>
        </div>
    </div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Log in{% endblock %}

{% block body %}

    <div class="min-h-[calc(100vh-5rem)] bg-primary flex items-center justify-center px-4 py-4">
        <div class="w-full max-w-sm">
            <div class="bg-card shadow rounded-lg p-6 max-h-full overflow-auto">
                <h1 class="text-2xl font-semibold text-white mb-6 text-center">Please sign in</h1>

                <a href="{{ path('connect_google_start') }}" class="w-full inline-flex items-center justify-center rounded-md border border-gray-600 bg-primary px-4 py-2 mb-2 text-white font-medium shadow-sm hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-accent">
                    Sign in with Google
                </a>
                <p class="text-center text-gray-400 text-md">or</p>
                {% if error %}
                    <div class="mb-4 rounded border border-red-400 bg-red-500/20 text-red-400 px-4 py-3 text-sm">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <form method="post" class="space-y-5">
                    <div>
                        <label for="username" class="block mb-2 text-sm font-medium text-gray-300">Email</label>
                        <input
                            type="email"
                            value="{{ last_username }}"
                            name="email"
                            id="username"
                            autocomplete="email"
                            required
                            autofocus
                            class="block w-full rounded-md border border-gray-600 bg-primary px-3 py-2 text-white placeholder-gray-500 shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent"
                        >
                    </div>

                    <div>
                        <label for="password" class="block mb-2 text-sm font-medium text-gray-300">Password</label>
                        <input
                            type="password"
                            name="password"
                            id="password"
                            autocomplete="current-password"
                            required
                            class="block w-full rounded-md border border-gray-600 bg-primary px-3 py-2 text-white placeholder-gray-500 shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent"
                        >
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <button type="submit" class="w-full inline-flex items-center justify-center rounded-md bg-accent px-4 py-2 text-white font-medium shadow-sm hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-accent" aria-label="Sign in to your account">
                        Sign in
                    </button>

                    <a href="{{ path('app_register') }}" class="w-full inline-flex items-center justify-center rounded-md bg-accent px-4 py-2 text-white font-medium shadow-sm hover:opacity-90 transition-colors focus:outline-none focus:ring-2 focus:ring-accent">
                        New User? Sign up
                    </a>
                </form>
            </div>
        </div>
    </div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block body %}
<div class="flex-1 flex flex-col items-center justify-center text-center px-4 min-h-0">
    <div class="bg-gray-800 p-8 rounded-2xl border border-gray-700 max-w-md shadow-2xl">
        <h1 class="text-4xl font-bold text-white mb-4">Error {{ status_code }}</h1>
        <h2 class="text-2xl text-white font-semibold mb-2">
            {{ status_text|default('Something went wrong') }}
        </h2>
        <p class="text-gray-400 mb-6">
            {% if status_code == 404 %}
                The page you are looking for does not exist.
            {% elseif status_code == 403 %}
                You don't have permission to access this page.
            {% else %}
                An unexpected error occurred. Please let us know what you were doing when this happened.
            {% endif %}
            <br>Select the button below to go back to the home page.
        </p>

        <a href="{{ path('app_coin_index') }}"
           class="inline-block bg-accent px-6 py-2 rounded-lg text-white font-medium hover:bg-opacity-90 transition-all">
            Back to Home
        </a>
    </div>
</div>
{% endblock %}
<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
            <script src="/js/transaction_price_sync.js"></script>
        {% endblock %}
    </head>
    <body class="min-h-screen" data-controller="confirm">
        {% include 'components/_navbar.html.twig' %}
        <div class="min-h-screen flex flex-col">
            <main class="flex-1 flex flex-col">
                {% for type, messages in app.flashes(['success', 'notice', 'error']) %}
                    {% for message in messages %}
                        <div class="max-w-7xl mx-auto px-4 mt-4 md:px-8">
                            <div class="px-4 py-3 rounded-lg {{ type == 'error' ? 'text-white border border-red-500/50' : (type == 'notice' ? 'text-white border border-amber-500/50' : 'text-white border border-green-500/50') }}">
                                {{ message }}
                            </div>
                        </div>
                    {% endfor %}
                {% endfor %}
                {% block body %}{% endblock %}
            </main>
            {% include 'components/_footer.html.twig' %}
        </div>
        {% include 'components/_confirm_modal.html.twig' %}
        {% if is_granted('IS_AUTHENTICATED_FULLY') %}
            <div class="fixed bottom-7 right-7 z-50" data-controller="chatbot">
                <button data-action="click->chatbot#toggle" class="bg-card p-4 rounded-full shadow-xl hover:scale-105 transition-all border border-white/10 hover:border-purple-500/50 focus:outline-none focus:ring-2 focus:ring-purple-500/50" aria-label="Open chatbot">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6 text-white"> <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" /></svg>
                </button>
                <div data-chatbot-target="window" class="hidden absolute bottom-20 right-0 w-80 rounded-2xl shadow-2xl flex flex-col overflow-hidden bg-card border border-white/10">
                    <div class="px-4 py-3 border-b border-primary">
                        <span class="text-white font-semibold text-sm">Cointer Assistant</span>
                        <p class="text-gray-400 text-S mt-0.5">Ask me anything about crypto, this is not financial advice.</p>
                    </div>
                    <div data-chatbot-target="messages" class="h-72 p-4 overflow-y-auto space-y-3 text-sm bg-primary [&::-webkit-scrollbar]:w-1.5 [&::-webkit-scrollbar-track]:bg-primary [&::-webkit-scrollbar-thumb]:bg-accent [&::-webkit-scrollbar-thumb]:rounded-full">
                        <div class="flex justify-start">
                            <div class="w-fit max-w-[85%] bg-card border border-white/10 rounded-lg px-3 py-2 text-gray-300">Hello! Ask me anything about crypto. Information may be incorrect from the AI, always verify with the website for accuracy<br>Information is not financial advice.</div>
                        </div>
                    </div>
                    <div class="p-3 border-t border-primary bg-card flex gap-2 items-center">
                        <input data-chatbot-target="input" type="text" placeholder="Type your message..." data-action="keydown.enter->chatbot#sendOnEnter" class="flex-1 min-w-0 rounded-lg border border-gray-600 bg-primary px-3 py-2 text-white text-sm placeholder-gray-500 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent">
                        <button data-action="click->chatbot#send" type="button" class="shrink-0 bg-accent hover:opacity-90 text-white font-medium px-4 py-2 rounded-lg transition-opacity">Send</button>
                    </div>
                </div>
            </div>
        {% endif %}
    </body>
</html>

{% extends 'base.html.twig' %}

{% block title %}Edit Profile - {{ user.displayName }}{% endblock %}

{% block body %}

    <div class="min-h-[calc(100vh-4rem)] bg-primary flex items-center justify-center px-4 py-4">
        <div class="w-full max-w-sm">
            <div class="bg-card shadow rounded-lg p-6 max-h-full overflow-auto">
                <h1 class="text-2xl font-semibold text-white mb-2 text-center">Edit Profile</h1>
                <p class="text-gray-400 text-sm text-center mb-6">{{ user.displayName }}</p>

                {% include 'user/_form.html.twig' with { button_label: 'Save Changes', user: user } %}

                <p class="mt-6 text-center">
                    <a href="{{ path('app_user_profile') }}" class="text-gray-400 text-md hover:text-white transition-colors">Cancel</a>
                </p>
            </div>
        </div>
    </div>
{% endblock %}
<form method="post" action="{{ path('app_user_delete') }}" onsubmit="return confirm('Are you sure you want to delete your account?');" class="inline">
    <input type="hidden" name="_token" value="{{ csrf_token('delete-user-' ~ user.id) }}">
    <button type="submit" class="px-2 py-1 text-s font-medium bg-red-500/10 text-red-400 hover:bg-red-500/20 border border-red-500/30 rounded transition-colors">
        <span>Delete Account</span>
    </button>
</form>
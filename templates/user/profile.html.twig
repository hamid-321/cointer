{% extends 'base.html.twig' %}

{% block title %}My Profile{% endblock %}

{% block body %}
<div class="min-h-screen bg-primary">

    <main class="px-4 pt-2 pb-6 md:px-8">
        <div class="max-w-2xl mx-auto">
            <h1 class="text-2xl font-bold text-white mb-6">My Profile</h1>

            <div class="bg-card rounded-2xl p-6 space-y-6">
                <div>
                    <label class="block text-gray-400 text-sm font-medium mb-1">Email</label>
                    <p class="text-white text-lg">{{ user.email }}</p>
                </div>
                <div>
                    <label class="block text-gray-400 text-sm font-medium mb-1">Display name</label>
                    <p class="text-white text-lg">{{ user.displayName }}</p>
                </div>
                <div class="flex items-center gap-2">
                    <a href="{{ path('app_user_edit') }}" class="px-2 py-1 text-s font-medium bg-slate-500/20 text-slate-300 hover:bg-slate-500/30 border border-slate-500/50 rounded transition-colors">
                        <span>Edit Profile</span>
                    </a>
                    {% include 'user/_delete_form.html.twig' with { user: user } %}
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}

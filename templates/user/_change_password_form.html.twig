{{ form_start(form, { attr: { class: 'space-y-5' } }) }}

    <div>
        <label for="{{ form.current_password.vars.id }}" class="block mb-2 text-sm font-medium text-gray-300">Current password</label>
        {{ form_widget(form.current_password, {
            attr: {
                class: 'block w-full rounded-md border border-gray-600 bg-primary px-3 py-2 text-white placeholder-gray-500 shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent'
            }
        }) }}
        {% if form.current_password.vars.errors|length > 0 %}
            <div class="mt-2 rounded border border-red-400 bg-red-500/20 text-red-400 px-4 py-3 text-sm" role="alert">
                {% for error in form.current_password.vars.errors %}
                    <span>{{ error.message }}</span><br>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    <div>
        <label for="{{ form.new_password.first.vars.id }}" class="block mb-2 text-sm font-medium text-gray-300">New password</label>
        {{ form_widget(form.new_password.first, {
            attr: {
                class: 'block w-full rounded-md border border-gray-600 bg-primary px-3 py-2 text-white placeholder-gray-500 shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent'
            }
        }) }}
        {% if form.new_password.first.vars.errors|length > 0 %}
            <div class="mt-2 rounded border border-red-400 bg-red-500/20 text-red-400 px-4 py-3 text-sm" role="alert">
                {% for error in form.new_password.first.vars.errors %}
                    <span>{{ error.message }}</span><br>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    <div>
        <label for="{{ form.new_password.second.vars.id }}" class="block mb-2 text-sm font-medium text-gray-300">Confirm new password</label>
        {{ form_widget(form.new_password.second, {
            attr: {
                class: 'block w-full rounded-md border border-gray-600 bg-primary px-3 py-2 text-white placeholder-gray-500 shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent'
            }
        }) }}
        {% if form.new_password.second.vars.errors|length > 0 %}
            <div class="mt-2 rounded border border-red-400 bg-red-500/20 text-red-400 px-4 py-3 text-sm" role="alert">
                {% for error in form.new_password.second.vars.errors %}
                    <span>{{ error.message }}</span><br>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    <button type="submit" class="w-full inline-flex items-center justify-center rounded-md bg-accent px-4 py-2 text-white font-medium shadow-sm hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-accent" aria-label="Change your password">
        Change password
    </button>
{{ form_end(form) }}

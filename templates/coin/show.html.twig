{% extends 'base.html.twig' %}

{% block title %}{{ coin.name }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-primary">

    <!-- Main Content -->
    <main class="px-4 pt-2 pb-6 md:px-8">
        <div class="max-w-4xl mx-auto">
            
            <!-- Back Link -->
            <a href="{{ path('app_coin_index') }}" class="inline-flex items-center text-gray-400 hover:text-white mb-4 transition-colors">
                <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                Back to list
            </a>

            <!-- Coin Header Card -->
            <div class="rounded-2xl p-6 bg-card mb-4">
                <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
                    <div>
                        <h1 class="text-2xl md:text-3xl font-bold text-white">{{ coin.name }}</h1>
                        <span class="text-gray-400 uppercase">{{ coin.symbol }}</span>
                    </div>
                    <div class="text-left md:text-right">
                        <div class="text-2xl md:text-3xl font-bold text-white">{{ coin.price|format_price }}</div>
                        {% set change = coin.change24h ?? 0 %}
                        <span class="{% if change >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                            {% if change >= 0 %}+{% endif %}{{ change|number_format(2) }}% (24h)
                        </span>
                    </div>
                </div>
            </div>

            <!-- Price Chart Card -->
            <div class="rounded-2xl p-6 bg-card mb-4">
                <h2 class="text-lg font-semibold text-white mb-4">Price History</h2>
                <div class="h-64 md:h-80">
                    {{ render_chart(chart) }}
                </div>
            </div>

            <!-- Coin Details Card -->
            <div class="rounded-2xl p-6 bg-card">
                <h2 class="text-lg font-semibold text-white mb-4">Details</h2>
                
                <div class="space-y-3">
                    <div class="flex justify-between py-3 border-b border-primary">
                        <span class="text-gray-400">Price</span>
                        <span class="text-white">{{ coin.price|format_price }}</span>
                    </div>
                    <div class="flex justify-between py-3 border-b border-primary">
                        <span class="text-gray-400">Market Cap</span>
                        <span class="text-white">{{ coin.marketCap|format_currency }}</span>
                    </div>
                    <div class="flex justify-between py-3 border-b border-primary">
                        <span class="text-gray-400">24h Change</span>
                        {% set change = coin.change24h ?? 0 %}
                        <span class="{% if change >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                            {% if change >= 0 %}+{% endif %}{{ change|number_format(2) }}%
                        </span>
                    </div>
                    <div class="flex justify-between py-3 border-b border-primary">
                        <span class="text-gray-400">Last Updated</span>
                        <span class="text-white">{{ coin.updatedAt|format_date }}</span>
                    </div>
                </div>
            </div>

        </div>
    </main>
</div>
{% endblock %}

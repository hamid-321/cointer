{% extends 'base.html.twig' %}

{% block title %}Coins{% endblock %}

{% block body %}
<div class="min-h-screen bg-primary">
    <!-- Main Content -->
    <main class="px-4 pt-2 pb-6 md:px-8">
        <div class="max-w-7xl mx-auto">
            
            {% if app.user %}
                <div class="mb-4">
                    <h1 class="text-2xl font-semibold text-white">Welcome, {{ app.user.displayName }}</h1>
                </div>
            {% endif %}
        
            <!-- Coins Table Card -->
            <div id="sortable-content" class="rounded-2xl p-4 md:p-6 bg-card">
                <!-- Header -->
                <div class="flex flex-col gap-4 mb-6">
                    <div class="flex items-center justify-between gap-2">
                        <h2 class="text-xl font-semibold text-white">All Coins</h2>
                        <span class="text-gray-400 text-sm whitespace-nowrap">Price updated {{ lastUpdated }}</span>
                    </div>
                    <form method="get" action="{{ path('app_coin_index') }}" class="flex flex-col gap-2 md:flex-row md:items-center md:gap-2">
                        <input type="text" name="q" value="{{ searchTerm }}" placeholder="Search coins by name or ticker..."
                            class="w-full md:w-auto md:min-w-[200px] flex-1 bg-gray-800 text-white px-4 py-2 rounded-lg border border-gray-700 focus:outline-none focus:border-accent">
                        <div class="flex gap-2">
                            <button type="submit" class="flex-1 md:flex-none bg-accent px-4 py-2 rounded-lg text-white font-medium hover:bg-purple-600 transition-colors">
                                Search
                            </button>
                            {% if searchTerm %}
                                <a href="{{ path('app_coin_index') }}" class="flex-1 md:flex-none text-center text-gray-400 hover:text-white px-4 py-2 rounded-lg border border-gray-600 hover:border-gray-500 transition-colors">
                                    Clear
                                </a>
                            {% endif %}
                        </div>
                    </form>
                </div>

                <!--  DESKTOP VIEW  -->
                <div class="hidden md:block">
                    <!-- Desktop Table Header -->
                    <div class="grid grid-cols-5 gap-4 px-4 pb-4 border-b border-primary">
                        <div class="text-gray-400 text-sm font-medium hover:text-white transition-colors">
                            {{ knp_pagination_sortable(pagination, 'Name', 'c.name', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                        </div>
                        <div class="text-gray-400 text-sm font-medium hover:text-white transition-colors">
                            {{ knp_pagination_sortable(pagination, 'Price', 'c.price', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                        </div>
                        <div class="text-gray-400 text-sm font-medium hover:text-white transition-colors">
                            {{ knp_pagination_sortable(pagination, '24h', 'c.change_24h', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                        </div>
                        <div class="text-gray-400 text-sm font-medium hover:text-white transition-colors">
                            {{ knp_pagination_sortable(pagination, 'Market Cap', 'c.market_cap', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                        </div>
                        <div></div>
                    </div>

                    <!-- Desktop Coin List -->
                    {% for coin in pagination %}
                        <a href="{{ path('app_coin_show', {'id': coin.id}) }}" 
                           class="grid grid-cols-5 gap-4 px-4 py-4 items-center border-b border-primary transition-colors hover:bg-[#2a2f3d]">
                            <div>
                                <div class="text-white font-medium">{{ coin.name }}</div>
                                <div class="text-gray-400 text-sm uppercase">{{ coin.symbol }}</div>
                            </div>
                            <div class="text-white">{{ coin.price|format_price }}</div>
                            <div>
                                {% set change = coin.change24h ?? 0 %}
                                <span class="{% if change >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                                    {% if change >= 0 %}+{% endif %}{{ change|number_format(1) }}%
                                </span>
                            </div>
                            <div class="text-white">{{ coin.marketCap|format_market_cap }}</div>
                            <div class="text-right">
                                <span class="text-gray-400">
                                    <svg class="w-5 h-5 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </span>
                            </div>
                        </a>
                    {% else %}
                        <div class="px-4 py-8 text-center text-gray-400">No coins found</div>
                    {% endfor %}
                </div>

                <!--  MOBILE VIEW  -->
                <div class="md:hidden">
                    <!-- Mobile Table Header -->
                    <div class="grid gap-2 px-1 pb-2 border-b border-primary" style="grid-template-columns: 0.95fr 1.05fr 0.75fr 1.25fr;">
                        <div class="text-gray-400 text-xs font-medium hover:text-white transition-colors">
                            {{ knp_pagination_sortable(pagination, 'Name', 'c.name', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                        </div>
                        <div class="text-gray-400 text-xs font-medium text-right hover:text-white transition-colors">
                            {{ knp_pagination_sortable(pagination, 'Price', 'c.price', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                        </div>
                        <div class="text-gray-400 text-xs font-medium text-right hover:text-white transition-colors">
                            {{ knp_pagination_sortable(pagination, '24h', 'c.change_24h', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                        </div>
                        <div class="text-gray-400 text-xs font-medium text-right hover:text-white transition-colors">
                            {{ knp_pagination_sortable(pagination, 'Market Cap', 'c.market_cap', { class: 'inline-flex items-center gap-1 cursor-pointer' }, [], 'components/_sortable_link.html.twig') }}
                        </div>
                    </div>

                    <!-- Mobile Coin List -->
                    {% for coin in pagination %}
                        <a href="{{ path('app_coin_show', {'id': coin.id}) }}" 
                           class="grid px-1 py-2 items-center border-b border-primary transition-colors hover:bg-[#2a2f3d]" style="grid-template-columns: 0.95fr 1.05fr 0.75fr 1.25fr;">
                            <div class="min-w-0">
                                <div class="text-white text-sm font-medium truncate">{{ coin.name }}</div>
                                <div class="text-gray-400 text-xs uppercase">{{ coin.symbol }}</div>
                            </div>
                            <div class="text-white text-sm text-right">{{ coin.price|format_price }}</div>
                            <div class="text-right">
                                {% set change = coin.change24h ?? 0 %}
                                <span class="text-sm {% if change >= 0 %}text-green-500{% else %}text-red-500{% endif %}">
                                    {% if change >= 0 %}+{% endif %}{{ change|number_format(1) }}%
                                </span>
                            </div>
                            <div class="text-white text-sm text-right">{{ coin.marketCap|format_market_cap }}</div>
                        </a>
                    {% else %}
                        <div class="px-4 py-8 text-center text-gray-400">No coins found</div>
                    {% endfor %}
                </div>

                {{ knp_pagination_render(pagination, 'components/_pagination.html.twig') }}
            </div>

        </div>
    </main>
</div>
{% endblock %}

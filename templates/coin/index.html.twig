{% extends 'base.html.twig' %}

{% block title %}Coin index{% endblock %}

{% block body %}
    <h1>Coin index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Coin_gecko_id</th>
                <th>Symbol</th>
                <th>Name</th>
                <th>Price</th>
                <th>Market_cap</th>
                <th>Change_24h</th>
                <th>Updated_at</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for coin in coins %}
            <tr>
                <td>{{ coin.id }}</td>
                <td>{{ coin.coinGeckoId }}</td>
                <td>{{ coin.symbol }}</td>
                <td>{{ coin.name }}</td>
                <td>{{ coin.price }}</td>
                <td>{{ coin.marketCap }}</td>
                <td>{{ coin.change24h }}</td>
                <td>{{ coin.updatedAt ? coin.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>
                    <a href="{{ path('app_coin_show', {'id': coin.id}) }}">show</a>
                    <a href="{{ path('app_coin_edit', {'id': coin.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="9">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_coin_new') }}">Create new</a>
{% endblock %}

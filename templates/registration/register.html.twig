{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
    {% include 'components/_navbar.html.twig' %}

    <div class="min-h-[calc(100vh-5rem)] bg-primary flex items-center justify-center px-4 py-4">
        <div class="w-full max-w-sm">
            <div class="bg-card shadow rounded-lg p-6 max-h-full overflow-auto">
                <h1 class="text-2xl font-semibold text-white mb-6 text-center">Create your account</h1>

                {{ form_errors(registrationForm) }}

                {{ form_start(registrationForm, { attr: { class: 'space-y-5' } }) }}
                    

                    <div>
                        <label for="{{ registrationForm.email.vars.id }}" class="block mb-2 text-sm font-medium text-gray-300">Email</label>
                        {{ form_widget(registrationForm.email, {
                            attr: {
                                class: 'block w-full rounded-md border border-gray-600 bg-primary px-3 py-2 text-white placeholder-gray-500 shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent'
                            }
                        }) }}
                        {% if registrationForm.email.vars.errors|length > 0 %}
                            <div class="mt-2 rounded border border-red-400 bg-red-500/20 text-red-400 px-4 py-3 text-sm" role="alert">
                                {% for error in registrationForm.email.vars.errors %}
                                    <span>{{ error.message }}</span><br>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    <div>
                        <label for="{{ registrationForm.displayName.vars.id }}" class="block mb-2 text-sm font-medium text-gray-300">Display Name</label>
                        {{ form_widget(registrationForm.displayName, {
                            attr: {
                                class: 'block w-full rounded-md border border-gray-600 bg-primary px-3 py-2 text-white placeholder-gray-500 shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent'
                            }
                        }) }}
                        {% if registrationForm.displayName.vars.errors|length > 0 %}
                            <div class="mt-2 rounded border border-red-400 bg-red-500/20 text-red-400 px-4 py-3 text-sm" role="alert">
                                {% for error in registrationForm.displayName.vars.errors %}
                                    <span>{{ error.message }}</span><br>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    <div>
                        <label for="{{ registrationForm.plainPassword.first.vars.id }}" class="block mb-2 text-sm font-medium text-gray-300">Password</label>
                        {{ form_widget(registrationForm.plainPassword.first, {
                            attr: {
                                class: 'block w-full rounded-md border border-gray-600 bg-primary px-3 py-2 text-white placeholder-gray-500 shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent'
                            }
                        }) }}
                        {% if registrationForm.plainPassword.first.vars.errors|length > 0 %}
                            <div class="mt-2 rounded border border-red-400 bg-red-500/20 text-red-400 px-4 py-3 text-sm" role="alert">
                                {% for error in registrationForm.plainPassword.first.vars.errors %}
                                    <span>{{ error.message }}</span><br>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    <div>
                        <label for="{{ registrationForm.plainPassword.second.vars.id }}" class="block mb-2 text-sm font-medium text-gray-300">Repeat Password</label>
                        {{ form_widget(registrationForm.plainPassword.second, {
                            attr: {
                                class: 'block w-full rounded-md border border-gray-600 bg-primary px-3 py-2 text-white placeholder-gray-500 shadow-sm focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent'
                            }
                        }) }}
                        {% if registrationForm.plainPassword.second.vars.errors|length > 0 %}
                            <div class="mt-2 rounded border border-red-400 bg-red-500/20 text-red-400 px-4 py-3 text-sm" role="alert">
                                {% for error in registrationForm.plainPassword.second.vars.errors %}
                                    <span>{{ error.message }}</span><br>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    <button type="submit" class="w-full inline-flex items-center justify-center rounded-md bg-accent px-4 py-2 text-white font-medium shadow-sm hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-accent">
                        Register
                    </button>
                {{ form_end(registrationForm) }}
            </div>
        </div>
    </div>
{% endblock %}

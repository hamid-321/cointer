<div data-confirm-target="backdrop" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60" data-action="click->confirm#close">
    <div class="bg-card rounded-2xl border border-gray-600 shadow-xl max-w-md w-full p-6 flex flex-col gap-4" data-action="click->confirm#stopPropagation">
        <h3 class="text-lg font-semibold text-white">Confirm</h3>
        <p data-confirm-target="message" class="text-gray-300"></p>
        <div class="flex justify-end gap-2 pt-2">
            <button type="button" class="px-4 py-2 text-sm font-medium text-gray-300 bg-slate-500/20 border border-slate-500/50 rounded-lg hover:bg-slate-500/30 transition-colors" data-action="click->confirm#close" aria-label="Cancel and close confirmation dialog">
                Cancel
            </button>
            <button type="button" class="px-4 py-2 text-sm font-medium text-white bg-red-500/80 border border-red-500/50 rounded-lg hover:bg-red-500 transition-colors" data-action="click->confirm#confirm" aria-label="Confirm delete">
                Delete
            </button>
        </div>
    </div>
</div>

<nav class="px-4 py-4 lg:px-8">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
        <!-- Logo -->
        <a href="{{ path('app_coin_index') }}" class="flex items-center">
            <img src="/images/logo.png" alt="Cointer" class="h-8 lg:h-10">
        </a>

        <!-- Desktop Navigation -->
        <div class="hidden lg:flex items-center gap-2">
            {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                {# User is logged in #}
                <a href="{{ path('app_coin_index') }}" class="px-4 py-2 text-white hover:bg-card rounded-lg transition-colors bg-button">Coin List</a>
                <a href="{{ path('app_portfolio_index') }}" class="px-4 py-2 text-white hover:bg-card rounded-lg transition-colors bg-button">Portfolio</a>
                <a href="{{ path('app_user_profile') }}" class="px-4 py-2 text-white hover:bg-card rounded-lg transition-colors bg-button">Profile</a>
                <a href="{{ path('app_logout') }}" class="px-4 py-2 text-white rounded-lg transition-colors bg-accent hover:opacity-90">Logout</a>
            {% else %}
                {# User is not logged in #}
                <a href="{{ path('app_coin_index') }}" class="px-4 py-2 text-white hover:bg-card rounded-lg transition-colors bg-button">Coin List</a>
                <a href="{{ path('app_portfolio_index') }}" class="px-4 py-2 text-white hover:bg-card rounded-lg transition-colors bg-button">Portfolio</a>
                <a href="{{ path('app_login') }}" class="px-4 py-2 text-white hover:bg-card rounded-lg transition-colors bg-button">Login</a>
                <a href="{{ path('app_register') }}" class="px-4 py-2 text-white rounded-lg transition-colors bg-accent">Sign Up</a>
            {% endif %}
        </div>

        <!-- Mobile Menu Button -->
        <button type="button" id="mobile-menu-btn" class="lg:hidden text-white p-2" aria-controls="mobile-menu" aria-expanded="false" aria-label="Toggle navigation menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
        </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden lg:hidden mt-4 pb-4">
        <div class="flex flex-col gap-2">
            {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                {# User is logged in #}
                <a href="{{ path('app_coin_index') }}" class="px-4 py-2 text-white hover:bg-card rounded-lg transition-colors bg-button text-center">Coin List</a>
                <a href="{{ path('app_portfolio_index') }}" class="px-4 py-2 text-white hover:bg-card rounded-lg transition-colors bg-button text-center">Portfolio</a>
                <a href="{{ path('app_user_profile') }}" class="px-4 py-2 text-white hover:bg-card rounded-lg transition-colors bg-button text-center">Profile</a>
                <a href="{{ path('app_logout') }}" class="px-4 py-2 text-white rounded-lg transition-colors text-center bg-accent hover:opacity-90">Logout</a>
            {% else %}
                {# User is not logged in #}
                <a href="{{ path('app_coin_index') }}" class="px-4 py-2 text-white hover:bg-card rounded-lg transition-colors bg-button text-center">Coin List</a>
                <a href="{{ path('app_portfolio_index') }}" class="px-4 py-2 text-white hover:bg-card rounded-lg transition-colors bg-button text-center">Portfolio</a>
                <a href="{{ path('app_login') }}" class="px-4 py-2 text-white hover:bg-card rounded-lg transition-colors bg-button text-center">Login</a>
                <a href="{{ path('app_register') }}" class="px-4 py-2 text-white rounded-lg transition-colors text-center bg-accent hover:opacity-90">Sign Up</a>
            {% endif %}
        </div>
    </div>
</nav>

<script>
    (function () {
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');
        btn.addEventListener('click', function () {
            menu.classList.toggle('hidden');
            const expanded = !menu.classList.contains('hidden');
            btn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
        });
    })();
</script>
